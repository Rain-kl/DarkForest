# ── Application ──
APP_NAME=DarkForest
APP_VERSION=0.1.0
DEBUG=false

# ── Database ──
DATABASE_URL=postgresql+asyncpg://darkforest:darkforest@db:5432/darkforest

# ── JWT ──
JWT_SECRET_KEY=change-me-to-a-strong-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Admin ──
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456
ADMIN_EMAIL=admin@darkforest.local

# ── Room Defaults ──
DEFAULT_ROOM_TIMEOUT_MINUTES=10
DEFAULT_MESSAGE_RETENTION_HOURS=24

# ── Rate Limiting ──
DEFAULT_MAX_ROOMS_PER_HOUR=5
DEFAULT_MAX_JOINS_PER_HOUR=10
DEFAULT_MAX_MESSAGES_PER_MINUTE=30

# ── CORS ──
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Redis (optional, for future use) ──
REDIS_URL=redis://redis:6379/0
